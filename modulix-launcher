#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  modulix-launcher --inventory-dir <PATH> services <wunderbox|aap> [--rebuild] [--playbook <PATH>] [ansible args...]
  modulix-launcher --inventory-dir <PATH> toolbox shell

Notes:
  RHEL control hosts only.
  --inventory-dir <PATH> sets the inventories root directory mounted into the runtime.
  -i/--inventory in [ansible args...] selects the concrete Ansible inventory file.
  Execution mode is nested-only with fixed host preload:
  host always exports RUN_EE_IMAGE and toolbox always loads it before run.
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

abs_path() {
  local p="$1"
  [[ "$p" == /* ]] || p="$PWD/$p"
  readlink -f -- "$p"
}

runner_path() {
  local p
  p="$(abs_path "$1")"
  case "$p" in
    "$PWD_ABS") echo "/runner/project" ;;
    "$PWD_ABS"/*) echo "/runner/project/${p#"$PWD_ABS"/}" ;;
    *) die "path must be inside current directory ($PWD_ABS): $1" ;;
  esac
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

[[ "$(uname -s)" == "Linux" ]] || die "modulix-launcher is supported only on RHEL control hosts"
[[ -f /etc/redhat-release ]] || die "modulix-launcher is supported only on RHEL control hosts"

PWD_ABS="$(abs_path "$PWD")"
INVENTORY_DIR=""
ANSIBLE_ROOT_HOST="$PWD_ABS/modulix-automation/ansible"
ANSIBLE_CONFIG_FILE_HOST="$ANSIBLE_ROOT_HOST/ansible.cfg"

case "${1:-}" in
  --inventory-dir)
    [[ -n "${2:-}" ]] || {
      usage
      die "missing required ${1} <PATH>"
    }
    INVENTORY_DIR="$(abs_path "$2")"
    shift 2
    ;;
  --inventory-dir=*)
    local_inv="${1#*=}"
    [[ -n "$local_inv" ]] || {
      usage
      die "${1%%=*} requires a non-empty value"
    }
    INVENTORY_DIR="$(abs_path "$local_inv")"
    shift
    ;;
  *)
    usage
    die "missing required --inventory-dir <PATH>"
    ;;
esac

case "$INVENTORY_DIR" in
  "$PWD_ABS"|"$PWD_ABS"/*) ;;
  *) die "--inventory-dir must be inside current directory ($PWD_ABS): $INVENTORY_DIR" ;;
esac
[[ -d "$INVENTORY_DIR" ]] || die "--inventory-dir is not a directory: $INVENTORY_DIR"
[[ -d "$ANSIBLE_ROOT_HOST" ]] || die "current directory must contain modulix-automation/ansible: $ANSIBLE_ROOT_HOST"
[[ -f "$ANSIBLE_CONFIG_FILE_HOST" && -r "$ANSIBLE_CONFIG_FILE_HOST" ]] || {
  die "required ansible.cfg missing or unreadable: $ANSIBLE_CONFIG_FILE_HOST"
}

RUN_EE_IMAGE="${RUN_EE_IMAGE:-quay.io/l-it/ee-wunder-ansible-ubi9-certified:v1.11.6}"
RUN_TOOLBOX_IMAGE="${RUN_TOOLBOX_IMAGE:-quay.io/l-it/ee-wunder-toolbox-ubi9:v1.7.2}"
VAULT_PASS_FILE="$(abs_path "${VAULT_PASS_FILE:-$ANSIBLE_ROOT_HOST/.vault-pass.txt}")"
RUN_SKIP_CERT_CHECK="${RUN_SKIP_CERT_CHECK:-false}"
RUN_ANSIBLE_LOCAL_TEMP="${ANSIBLE_LOCAL_TEMP:-/tmp/.ansible/tmp}"
RUN_ANSIBLE_REMOTE_TEMP="${ANSIBLE_REMOTE_TEMP:-~/.ansible/tmp}"
RUN_VAULT_TOKEN="${VAULT_TOKEN:-${ROOT_TOKEN:-}}"

case "$RUN_SKIP_CERT_CHECK" in
  true|false) ;;
  *) die "RUN_SKIP_CERT_CHECK must be true or false (got: $RUN_SKIP_CERT_CHECK)" ;;
esac

case "$VAULT_PASS_FILE" in
  "$PWD_ABS"|"$PWD_ABS"/*) ;;
  *) die "VAULT_PASS_FILE must be inside current directory ($PWD_ABS): $VAULT_PASS_FILE" ;;
esac
[[ -f "$VAULT_PASS_FILE" && -r "$VAULT_PASS_FILE" && -s "$VAULT_PASS_FILE" ]] || {
  die "required file missing or unreadable: $VAULT_PASS_FILE"
}

RUNNER_INVENTORY_DIR="$(runner_path "$INVENTORY_DIR")"
RUNNER_VAULT_PASS_FILE="$(runner_path "$VAULT_PASS_FILE")"
RUNNER_ANSIBLE_CONFIG="$(runner_path "$ANSIBLE_CONFIG_FILE_HOST")"
RUNNER_ANSIBLE_ROOT="$(runner_path "$ANSIBLE_ROOT_HOST")"
SSH_SOURCE_HOST=""

ensure_image_available_on_host() {
  local image="$1"
  if podman image exists "$image" >/dev/null 2>&1; then
    return 0
  fi

  if [[ "$image" == localhost/* ]]; then
    die "local image not found: $image"
  fi

  if [[ "$RUN_SKIP_CERT_CHECK" == "true" ]]; then
    podman pull --tls-verify=false "$image" >/dev/null
    return 0
  fi

  podman pull "$image" >/dev/null
}

discover_ssh_access() {
  local ssh_source_candidate="$HOME/.ssh"

  [[ -d "$ssh_source_candidate" ]] || die "required SSH directory missing: $ssh_source_candidate"
  SSH_SOURCE_HOST="$(abs_path "$ssh_source_candidate")"
  [[ -d "$SSH_SOURCE_HOST" ]] || die "required SSH directory missing: $SSH_SOURCE_HOST"
}

run_toolbox() {
  local interactive="$1"
  shift

  local tty=()
  [[ "$interactive" == true ]] && tty=( -it )
  local ee_volume_mounts="${ANSIBLE_NAVIGATOR_EXECUTION_ENVIRONMENT_VOLUME_MOUNTS:-/opt/modulix:/opt/modulix:Z}"

  local envs=(
    -e HOME=/runner/project
    -e ANSIBLE_TOOLBOX_NAV_EE_ENABLED=true
    -e "ANSIBLE_TOOLBOX_NAV_EE_IMAGE=$RUN_EE_IMAGE"
    -e "ANSIBLE_TOOLBOX_NAV_SKIP_CERT_CHECK=$RUN_SKIP_CERT_CHECK"
    -e ANSIBLE_TOOLBOX_AUTO_COLLECTIONS=false
    -e "ANSIBLE_VAULT_PASSWORD_FILE=$RUNNER_VAULT_PASS_FILE"
    -e "ANSIBLE_NAVIGATOR_EXECUTION_ENVIRONMENT_VOLUME_MOUNTS=$ee_volume_mounts"
    -e "ANSIBLE_LOCAL_TEMP=$RUN_ANSIBLE_LOCAL_TEMP"
    -e "ANSIBLE_REMOTE_TEMP=$RUN_ANSIBLE_REMOTE_TEMP"
    -e ANSIBLE_TOOLBOX_NAV_PULL_POLICY=never
    -e "ANSIBLE_CONFIG=$RUNNER_ANSIBLE_CONFIG"
  )
  [[ -n "$RUN_VAULT_TOKEN" ]] && envs+=( -e "VAULT_TOKEN=${RUN_VAULT_TOKEN}" )

  podman run --rm "${tty[@]}" \
    --privileged \
    --security-opt label=disable \
    --user 0:0 \
    -w /runner/project \
    -v "$PWD_ABS:/runner/project:Z" \
    -v "$SSH_SOURCE_HOST:/runner/project/.ssh:ro" \
    -v "$SSH_SOURCE_HOST:/root/.ssh:ro" \
    "${envs[@]}" \
    "$RUN_TOOLBOX_IMAGE" \
    "$@"
}

rewrite_inventory_args() {
  local out=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -i|--inventory)
        [[ $# -ge 2 ]] || die "$1 requires a value"
        if [[ "$2" == inventories/* ]]; then
          out+=( "$1" "$RUNNER_INVENTORY_DIR/${2#inventories/}" )
        else
          out+=( "$1" "$2" )
        fi
        shift 2
        ;;
      --inventory=*)
        local inv="${1#*=}"
        if [[ "$inv" == inventories/* ]]; then
          out+=( "--inventory=$RUNNER_INVENTORY_DIR/${inv#inventories/}" )
        else
          out+=( "$1" )
        fi
        shift
        ;;
      *)
        out+=( "$1" )
        shift
        ;;
    esac
  done
  printf '%s\0' "${out[@]}"
}

resolve_service_playbook() {
  local service="$1"
  local rebuild="$2"
  local playbook_override="${3:-}"

  if [[ -n "$playbook_override" ]]; then
    case "$playbook_override" in
      /*) printf '%s\n' "$playbook_override" ;;
      playbooks/*) printf '%s\n' "${RUNNER_ANSIBLE_ROOT}/$playbook_override" ;;
      *) die "invalid --playbook path '$playbook_override' (use absolute path or playbooks/...)" ;;
    esac
    return 0
  fi

  case "${service}:${rebuild}" in
    wunderbox:true) printf '%s\n' "${RUNNER_ANSIBLE_ROOT}/playbooks/services/01-wunderbox-rebuild.yml" ;;
    wunderbox:false) printf '%s\n' "${RUNNER_ANSIBLE_ROOT}/playbooks/stage-2b/12-wunderbox.yml" ;;
    aap:true) printf '%s\n' "${RUNNER_ANSIBLE_ROOT}/playbooks/services/02-aap-rebuild.yml" ;;
    aap:false) printf '%s\n' "${RUNNER_ANSIBLE_ROOT}/playbooks/stage-2b/13-aap.yml" ;;
    *) die "unsupported service '$service' (use: wunderbox | aap)" ;;
  esac
}

parse_service_args() {
  SERVICE_REBUILD=false
  SERVICE_PLAYBOOK_OVERRIDE=""
  SERVICE_ARGS_INCLUDE_VAULT_TOKEN=false
  SERVICE_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --rebuild|-r|rebuild)
        SERVICE_REBUILD=true
        ;;
      --playbook|-p)
        [[ $# -ge 2 ]] || die "--playbook requires a value"
        SERVICE_PLAYBOOK_OVERRIDE="$2"
        shift
        ;;
      --playbook=*|-p=*)
        SERVICE_PLAYBOOK_OVERRIDE="${1#*=}"
        [[ -n "$SERVICE_PLAYBOOK_OVERRIDE" ]] || die "--playbook requires a non-empty value"
        ;;
      -e|--extra-vars)
        [[ $# -ge 2 ]] || die "--extra-vars requires a value"
        [[ "$2" == *"vault_token="* ]] && SERVICE_ARGS_INCLUDE_VAULT_TOKEN=true
        SERVICE_ARGS+=( "$1" "$2" )
        shift
        ;;
      -e=*|--extra-vars=*)
        [[ "$1" == *"vault_token="* ]] && SERVICE_ARGS_INCLUDE_VAULT_TOKEN=true
        SERVICE_ARGS+=( "$1" )
        ;;
      *)
        SERVICE_ARGS+=( "$1" )
        ;;
    esac
    shift
  done
}

require_service_targets() {
  local has_inventory=false
  local has_limit=false
  local a

  for a in "$@"; do
    [[ "$a" == "-i" || "$a" == "--inventory" || "$a" == --inventory=* ]] && has_inventory=true
    [[ "$a" == "-l" || "$a" == "--limit" ]] && has_limit=true
  done
  [[ "$has_inventory" == true ]] || die "services mode requires ansible -i/--inventory <FILE> (separate from top-level --inventory-dir)"
  [[ "$has_limit" == true ]] || die "services mode requires -l/--limit (no environment-specific default host is assumed)"
}

run_services() {
  local service="$1"
  shift || true

  discover_ssh_access
  parse_service_args "$@"

  if [[ -n "$RUN_VAULT_TOKEN" && "$SERVICE_ARGS_INCLUDE_VAULT_TOKEN" == false ]]; then
    SERVICE_ARGS+=( -e "vault_token=$RUN_VAULT_TOKEN" )
  fi

  local playbook=""
  playbook="$(resolve_service_playbook "$service" "$SERVICE_REBUILD" "$SERVICE_PLAYBOOK_OVERRIDE")"
  require_service_targets "${SERVICE_ARGS[@]}"

  local run_args=()
  while IFS= read -r -d '' a; do
    run_args+=( "$a" )
  done < <(rewrite_inventory_args "${SERVICE_ARGS[@]}")

  local nav_local="${RUNNER_ANSIBLE_ROOT}/scripts/ansible-nav-local"

  ensure_image_available_on_host "$RUN_TOOLBOX_IMAGE"
  ensure_image_available_on_host "$RUN_EE_IMAGE"

  local ee_archive=""
  local runner_ee_archive=""
  local cache_dir="$PWD_ABS/.modulix-launcher-cache"
  mkdir -p -- "$cache_dir"
  ee_archive="$(mktemp "$cache_dir/run-ee-image.XXXXXX.tar")"
  runner_ee_archive="$(runner_path "$ee_archive")"

  if ! podman save -o "$ee_archive" "$RUN_EE_IMAGE" >/dev/null; then
    rm -f -- "$ee_archive"
    die "failed to export run EE image from host store: $RUN_EE_IMAGE"
  fi

  if ! run_toolbox true bash -lc '
    set -euo pipefail
    ee_archive="$1"
    nav_local="$2"
    shift 2
    podman load -i "$ee_archive" >/dev/null
    exec "$nav_local" run "$@"
  ' -- "$runner_ee_archive" "$nav_local" "$playbook" "${run_args[@]}"; then
    rm -f -- "$ee_archive"
    return 1
  fi

  rm -f -- "$ee_archive"
}

run_toolbox_shell() {
  discover_ssh_access

  ensure_image_available_on_host "$RUN_TOOLBOX_IMAGE"
  run_toolbox true /bin/bash
}

mode="${1:-}"
case "$mode" in
  services)
    service="${2:-wunderbox}"
    shift $(( $# >= 2 ? 2 : $# ))
    run_services "$service" "$@"
    ;;
  toolbox)
    sub="${2:-shell}"
    shift $(( $# >= 2 ? 2 : $# ))
    case "$sub" in
      shell) run_toolbox_shell "$@" ;;
      *) die "unsupported toolbox subcommand '$sub' (use: shell)" ;;
    esac
    ;;
  *)
    usage
    die "unsupported mode '$mode' (expected: services | toolbox)"
    ;;
esac
